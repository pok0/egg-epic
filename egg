<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Precision AI Egg Analysis (Thai Standard)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #4A90E2;
      --primary-hover: #357ABD;
      --background-color: #f0f4f8;
      --card-background: #ffffff;
      --text-color: #333;
      --label-color: #555;
      --border-color: #dbe2e8;
      --error-color: #dc3545;
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--background-color);
      color: var(--text-color);
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
      margin: 0;
      box-sizing: border-box;
    }
    .calculator-container {
      background-color: var(--card-background);
      padding: 30px 40px;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
      width: 100%;
      max-width: 600px;
      border: 1px solid var(--border-color);
    }
    h2 {
      color: var(--text-color);
      font-weight: 700;
      text-align: center;
      margin-top: 0;
      margin-bottom: 25px;
    }
    
    .image-container {
      position: relative;
      margin-bottom: 20px;
      border: 2px dashed var(--border-color);
      border-radius: 12px;
      overflow: hidden;
      background: #fafafa;
      min-height: 150px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    #imagePreview {
      max-width: 100%;
      max-height: 350px;
      display: none;
      object-fit: contain;
    }

    .loader {
      display: none;
      margin: 15px auto;
      border: 3px solid #f3f3f3;
      border-top: 3px solid var(--primary-color);
      border-radius: 50%;
      width: 24px;
      height: 24px;
      animation: spin 1s linear infinite;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

    button {
      width: 100%;
      padding: 14px;
      font-size: 16px;
      font-weight: 700;
      color: white;
      background-color: var(--primary-color);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 10px;
      transition: all 0.2s;
    }
    button:hover {
      background-color: var(--primary-hover);
      transform: translateY(-1px);
    }
    #result {
      font-size: 14px;
      margin-top: 25px;
      color: var(--text-color);
      word-wrap: break-word;
      line-height: 1.8;
      background-color: #f8f9fa;
      padding: 20px;
      border-radius: 10px;
      border: 1px solid var(--border-color);
    }
    .result-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px 20px;
    }
    .result-item b { color: var(--primary-color); font-weight: 600; }
    .full-width { grid-column: 1 / -1; border-bottom: 1px solid #eee; padding-bottom: 8px; margin-bottom: 8px; }
    .status-msg { font-size: 12px; margin-top: 8px; text-align: center; padding: 6px; border-radius: 4px; font-weight: 500; width: 100%; box-sizing: border-box;}
    .error { background: #fff5f5; color: var(--error-color); }
    .success { background: #f0fff4; color: #28a745; }
    .warning { background: #fffaf0; color: #b7791f; }
    
    .input-row { display: flex; gap: 10px; margin-bottom: 20px; }
    .input-field { flex: 1; }
    .input-field label { display: block; margin-bottom: 5px; font-size: 13px; font-weight: 600; color: var(--label-color); }
    input, select {
      width: 100%;
      padding: 10px;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      font-size: 14px;
    }

    .formula-details {
      margin-top: 20px;
      border: 1px solid var(--border-color);
      border-radius: 8px;
      overflow: hidden;
    }
    .formula-header {
      background: #eee;
      padding: 10px 15px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .formula-content {
      display: none;
      padding: 15px;
      font-family: 'Courier New', monospace;
      font-size: 11px;
      background: #fafafa;
      max-height: 400px;
      overflow-y: auto;
    }
    .formula-content pre { margin: 0; white-space: pre-wrap; font-family: inherit; }
  </style>
</head>
<body>
  <div class="calculator-container">
    <h2>🥚 Thai Egg Precision AI (YOLO-Vision)</h2>

    <div class="image-container" onclick="document.getElementById('fileInput').click()">
      <div id="uploadPlaceholder" style="text-align:center; padding: 20px;">
        <p>📸 <b>Tap to Upload/Capture Egg</b></p>
        <p style="font-size: 11px; color: #666;">AI YOLO detects shell & Thai coins for scaling.</p>
      </div>
      <img id="imagePreview" alt="Preview">
      <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="processImage(this)">
    </div>

    <div id="visionLoader" class="loader"></div>
    <p id="statusMessage" class="status-msg"></p>

    <div class="input-row">
      <div class="input-field" style="flex: 2;">
        <label>Thai Egg Grade Reference:</label>
        <select id="eggSize">
          <option value="0">Grade 0 (Jumbo: ~61.0mm)</option>
          <option value="1" selected>Grade 1 (Large: ~58.0mm)</option>
          <option value="2">Grade 2 (Medium: ~55.0mm)</option>
          <option value="3">Grade 3 (Small: ~52.0mm)</option>
          <option value="4">Grade 4 (Extra Small: ~49.0mm)</option>
        </select>
      </div>
    </div>
    
    <div class="input-row">
      <div class="input-field">
        <label>Length (mm):</label>
        <input type="number" id="eggLength" step="0.0001">
      </div>
      <div class="input-field">
        <label>Width (mm):</label>
        <input type="number" id="eggWidth" step="0.0001">
      </div>
    </div>

    <button onclick="computeMetrics()">Analyze Thai Egg Data</button>

    <div id="result">Capture photo to begin analysis.</div>

    <div class="formula-details">
      <div class="formula-header" onclick="toggleFormula()">
        <span>🧬 VIEW COMPREHENSIVE EGG & ALBUMEN VALUES</span>
        <span id="formulaArrow">▼</span>
      </div>
      <div id="formulaContent" class="formula-content">
        <pre><i>Analyze an egg to calculate detailed component values...</i></pre>
      </div>
    </div>
  </div>

  <script>
    const apiKey = ""; 
    const eggData = [
      { g: 0.21, whitePercent: 0.712, yolkPercent: 0.288, baseline: 61.0 },
      { g: 0.21, whitePercent: 0.698, yolkPercent: 0.302, baseline: 58.0 },
      { g: 0.23, whitePercent: 0.682, yolkPercent: 0.318, baseline: 55.0 },
      { g: 0.22, whitePercent: 0.684, yolkPercent: 0.307, baseline: 52.0 },
      { g: 0.22, whitePercent: 0.680, yolkPercent: 0.320, baseline: 49.0 }
    ];

    function toggleFormula() {
      const content = document.getElementById('formulaContent');
      const arrow = document.getElementById('formulaArrow');
      const isVisible = content.style.display === 'block';
      content.style.display = isVisible ? 'none' : 'block';
      arrow.innerText = isVisible ? '▼' : '▲';
    }

    async function processImage(input) {
      if (!input.files || !input.files[0]) return;
      const file = input.files[0];
      const reader = new FileReader();
      const preview = document.getElementById('imagePreview');
      const placeholder = document.getElementById('uploadPlaceholder');
      const loader = document.getElementById('visionLoader');
      const statusMsg = document.getElementById('statusMessage');

      reader.onload = async (e) => {
        preview.src = e.target.result;
        preview.style.display = 'block';
        placeholder.style.display = 'none';
        loader.style.display = 'block';
        statusMsg.innerHTML = "AI YOLO Detection in progress...";
        statusMsg.className = "status-msg warning";

        const base64Data = e.target.result.split(',')[1];
        const gradeIdx = parseInt(document.getElementById('eggSize').value);
        const baselineLen = eggData[gradeIdx].baseline;
        
        try {
          const res = await detectEggDimensions(base64Data);
          if (res && res.egg_bbox) {
            let finalLength, finalWidth, methodMsg;
            const imgW = preview.naturalWidth;
            const imgH = preview.naturalHeight;

            if (res.coin_detected && res.coin_detected !== "none" && res.coin_bbox?.length === 4) {
                const coinSizes = { "10B": 26.0, "5B": 24.0, "1B": 20.0 };
                const coinRealSize = coinSizes[res.coin_detected] || 26.0;
                const egg_h_px = ((res.egg_bbox[2] - res.egg_bbox[0]) / 1000) * imgH;
                const egg_w_px = ((res.egg_bbox[3] - res.egg_bbox[1]) / 1000) * imgW;
                const coin_h_px = ((res.coin_bbox[2] - res.coin_bbox[0]) / 1000) * imgH;
                const coin_w_px = ((res.coin_bbox[3] - res.coin_bbox[1]) / 1000) * imgW;
                const coin_pixel_size = Math.max(coin_h_px, coin_w_px);
                const ratio = coinRealSize / coin_pixel_size;
                finalLength = Math.max(egg_h_px, egg_w_px) * ratio;
                finalWidth = Math.min(egg_h_px, egg_w_px) * ratio;
                statusMsg.className = "status-msg success";
                methodMsg = `✅ YOLO: Thai ${res.coin_detected} detected.`;
            } else {
                finalLength = baselineLen;
                const egg_h_px = ((res.egg_bbox[2] - res.egg_bbox[0]) / 1000) * imgH;
                const egg_w_px = ((res.egg_bbox[3] - res.egg_bbox[1]) / 1000) * imgW;
                finalWidth = finalLength * (Math.min(egg_h_px, egg_w_px) / Math.max(egg_h_px, egg_w_px));
                statusMsg.className = "status-msg warning";
                methodMsg = `📐 YOLO: Shell detected (Thai Grade ${gradeIdx} scale).`;
            }

            document.getElementById('eggLength').value = finalLength.toFixed(4);
            document.getElementById('eggWidth').value = finalWidth.toFixed(4);
            statusMsg.innerHTML = methodMsg;
            computeMetrics();
          }
        } catch (err) {
          statusMsg.className = "status-msg error";
          statusMsg.innerHTML = "⚠️ YOLO detection failed.";
        } finally {
          loader.style.display = 'none';
        }
      };
      reader.readAsDataURL(file);
    }

    async function detectEggDimensions(base64) {
      // Act as a YOLOv8 detector
      const prompt = `YOLO TASK:
      1. Detect [egg_shell] bounding box [ymin, xmin, ymax, xmax].
      2. Detect [thai_coin] (Classes: 10B, 5B, 1B).
      Return JSON: {"egg_bbox": [], "coin_detected": "10B"|"5B"|"1B"|"none", "coin_bbox": [], "confidence": 0.98}`;
      
      let retries = 0;
      while (retries < 5) {
        try {
          const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType: "image/png", data: base64 } }] }],
              generationConfig: { responseMimeType: "application/json", temperature: 0.1 }
            })
          });
          const result = await response.json();
          return JSON.parse(result.candidates?.[0]?.content?.parts?.[0]?.text);
        } catch (e) {
          retries++;
          await new Promise(r => setTimeout(r, Math.pow(2, retries) * 1000));
        }
      }
      return null;
    }

    function computeMetrics() {
      const resultEl = document.getElementById('result');
      const sizeIdx = parseInt(document.getElementById('eggSize').value);
      const length = parseFloat(document.getElementById('eggLength').value);
      const width = parseFloat(document.getElementById('eggWidth').value);
      
      if (isNaN(length) || isNaN(width) || length <= 0 || width <= 0) return;

      const a = length / 2.0;
      const b = width / 2.0;
      const { g, whitePercent, yolkPercent } = eggData[sizeIdx];
      const k = (2 * (g + (1 / 3) * (g ** 3))) / b;

      if (k * a >= 1 || k * a <= -1 || k === 0 || a === 0) {
          resultEl.innerHTML = `<span class="error">❌ Calculation error: Geometry invalid.</span>`;
          return;
      }

      const pi = Math.PI;
      const vol_ka = k * a;
      const base_vol = pi * (b**2) / k;
      const vol_term_1 = 2 / vol_ka;
      const vol_term_2 = (1 - (1 / (vol_ka**2))) * Math.log((1 + vol_ka) / (1 - vol_ka));
      const volume_mm3 = base_vol * (vol_term_1 + vol_term_2);
      
      let surface_area_mm2 = 0;
      try {
        const sa_term_A = (b/a) * ((1/(1+vol_ka)) - (1/(1-vol_ka)));
        const calc_sa_term = (s1, f, s2) => {
            const d1 = 5 + s1 * f * vol_ka;
            const d2_b = (1 + s2 * f * vol_ka / 5);
            const d2 = 4 * (a**4) * (d2_b**3);
            const i1 = (f === 3) ? 16/25 : 24/25;
            const i2_n_b = ((f === 3 ? 34 : 26) * (a**2) * k / 25) + (s2 * (f === 3 ? 6 : 2) * a / 5);
            return Math.sqrt((5 / d1) * (i1 + ((b**2) * (i2_n_b**2) / d2)));
        };

        const sa_term_B = calc_sa_term(-1,3,-1);
        const sa_term_C = calc_sa_term(-1,1,-1);
        const sa_term_D = calc_sa_term(1,3,1);
        const sa_term_E = calc_sa_term(1,1,1);

        const sa_combined = sa_term_A + 2 * sa_term_B * sa_term_C * sa_term_D * sa_term_E;
        surface_area_mm2 = (a/5) * sa_combined;
      } catch (e) {
        resultEl.innerHTML = `<span class="error">❌ Calculation Error.</span>`;
        return;
      }

      const shell_vol = surface_area_mm2 * 0.06; 
      const edible_vol = (volume_mm3 * 0.95) - shell_vol;
      
      const white_vol_ml = whitePercent * edible_vol / 1000;
      const yolk_vol_ml = yolkPercent * edible_vol / 1000;
      const total_edible_weight_g = (edible_vol / 1000) * 1.03;
      const albumen_weight_g = white_vol_ml * 1.03;

      // Values for total egg
      const total_protein = total_edible_weight_g * 0.126;
      const folic_mcg = total_edible_weight_g * 0.48;
      const choline_mg = total_edible_weight_g * 2.94;
      
      // Specific Albumen (White) metrics
      const albumen_protein = albumen_weight_g * 0.108;
      const albumen_potassium = albumen_weight_g * 1.63; // mg
      const albumen_riboflavin = albumen_weight_g * 0.004; // mg

      document.getElementById('formulaContent').innerHTML = `
<pre><b>--- PRECISION EGG & ALBUMEN VALUES ---</b>
Edible Weight:  ${total_edible_weight_g.toFixed(2)}g

<b>Total Egg Profile:</b>
Protein (Total):~${total_protein.toFixed(2)} g
Folic (B9):     ~${folic_mcg.toFixed(2)} mcg
Choline:        ~${choline_mg.toFixed(2)} mg
Vitamin A:      ~${(total_edible_weight_g * 1.6).toFixed(2)} mcg
Vitamin D:      ~${(total_edible_weight_g * 0.02).toFixed(3)} mcg
Iron:           ~${(total_edible_weight_g * 0.018).toFixed(3)} mg

<b>Albumen (Egg White) Focus:</b>
Albumen Mass:   ~${albumen_weight_g.toFixed(2)} g
Albumen Protein:~${albumen_protein.toFixed(2)} g
Potassium:      ~${albumen_potassium.toFixed(2)} mg
Riboflavin (B2):~${albumen_riboflavin.toFixed(3)} mg

<i>*Calculations derived via YOLO geometric modeling.</i>
</pre>`;

      resultEl.innerHTML = `
        <div class="result-grid">
          <div class="result-item full-width"><strong>Total Volume:</strong> <b>${(volume_mm3/1000).toFixed(4)} ml</b></div>
          <div class="result-item"><strong>Surface Area:</strong> <b>${surface_area_mm2.toFixed(2)} mm²</b></div>
          <div class="result-item"><strong>Edible Vol:</strong> <b>${(edible_vol/1000).toFixed(4)} ml</b></div>
          <div class="result-item"><strong>Albumen (White):</strong> <b>${white_vol_ml.toFixed(4)} ml</b></div>
          <div class="result-item"><strong>Yolk:</strong> <b>${yolk_vol_ml.toFixed(4)} ml</b></div>
        </div>
      `;
    }
  </script>
</body>
</html>
